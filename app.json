{
  "expo": {
    "name": "Remixr",
    "slug": "Remixr",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "sypher",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/logo.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sypher.mobile"
    },
    "android": {
      "permissions": ["FOREGROUND_SERVICE", "WAKE_LOCK"],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": "true",
          "data": [{ "scheme": "https", "host": "www.re-mixed.net"}],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#00AFA3"
      },
      "package": "com.sypher.mobile",
      "versionCode": 3
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "supabaseUrl": "https://hwmhookhaagcfkbzevko.supabase.co",
